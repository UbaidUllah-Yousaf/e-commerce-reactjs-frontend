# Optional. If set, browser calls this origin directly (Django must allow CORS).
# If unset, dev server proxies /api → http://localhost:8000 (see vite.config.ts).
# VITE_API_ORIGIN=http://localhost:8000

# Django session + CSRF: allow the Vite dev server Origin header, e.g. in settings.py:
# CSRF_TRUSTED_ORIGINS = ["http://localhost:5173", "http://127.0.0.1:5173"]
